# ============================================================
# Stock Opname Lab — Environment Variables
# Copy this file to .env and fill in the values.
# On Vercel, set these in Project Settings → Environment Variables.
# ============================================================

# ------------------------------------------------------------
# Database (required in all environments)
# ------------------------------------------------------------
# PostgreSQL connection string. On Vercel, use Vercel Postgres,
# Neon, Supabase, or any other managed PostgreSQL service.
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# ------------------------------------------------------------
# API server (required for local development only)
# ------------------------------------------------------------
# Port the Express API server listens on.
# Not needed on Vercel — the serverless function has no fixed port.
PORT=8080

# ------------------------------------------------------------
# Session secret (set if you add authentication later)
# ------------------------------------------------------------
# Must be a long, random string. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-string

# ------------------------------------------------------------
# Notifikasi Email — via SMTP (Nodemailer)
# Gunakan Gmail dengan "App Password", atau layanan SMTP lain.
# Kosongkan semua jika tidak ingin notifikasi email.
# ------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=emailkamu@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx
NOTIFY_EMAIL_FROM=emailkamu@gmail.com
# Bisa lebih dari satu, pisahkan dengan koma
NOTIFY_EMAIL_TO=penerima1@gmail.com,penerima2@gmail.com

# ------------------------------------------------------------
# Notifikasi WhatsApp — via Fonnte (https://fonnte.com)
# Daftar di fonnte.com, hubungkan nomor WA, copy token-nya.
# Kosongkan jika tidak ingin notifikasi WhatsApp.
# ------------------------------------------------------------
FONNTE_TOKEN=your-fonnte-api-token
# Nomor tujuan format internasional (628xxx). Bisa lebih dari satu, pisah koma.
NOTIFY_WA_TO=6281234567890,6289876543210

# ------------------------------------------------------------
# Replit-specific (NOT needed on Vercel or local dev)
# ------------------------------------------------------------
# BASE_PATH is injected automatically by the Replit platform.
# Do not set this manually unless you know what you are doing.
# BASE_PATH=/
