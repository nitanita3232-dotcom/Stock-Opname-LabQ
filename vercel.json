{
  "buildCommand": "pnpm --filter @workspace/api-server build && pnpm --filter @workspace/lab-stock build",
  "outputDirectory": "artifacts/lab-stock/dist/public",
  "framework": null,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/index.ts": {
      "maxDuration": 30
    }
  }
}
