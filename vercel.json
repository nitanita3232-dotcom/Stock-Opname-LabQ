{
  "buildCommand": "pnpm --filter @workspace/lab-stock build",
  "outputDirectory": "artifacts/lab-stock/dist/public",
  "framework": null,
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/index.ts": {
      "maxDuration": 30
    }
  }
}
